# gmail
GMAIL_USER=gmail_address@gmail.com
GMAIL_APP_PASSWORD=app_password
CONTACT_RECIPIENT_EMAIL=recipient@example.com

# github — powers the dates/commit counts behind the /projects sorting.
# Needs the `repo` scope: several of the linked repos are private and are invisible without it.
# Without this the page silently falls back to the hand-written dates in lib/projects/projects.ts.
GITHUB_TOKEN=ghp_xxx
